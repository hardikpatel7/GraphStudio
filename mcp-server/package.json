{
  "name": "smartstudio-mcp",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "MCP server exposing SmartStudio's article_selection DataView to Claude Code",
  "main": "dist/index.js",
  "bin": {
    "smartstudio-mcp": "dist/index.js",
    "smartstudio-mcp-http": "dist/index-http.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "dev:http": "tsx src/index-http.ts",
    "start": "node dist/index.js",
    "start:http": "node dist/index-http.js",
    "clean": "rm -rf dist release",
    "pack:release": "bash scripts/pack-release.sh",
    "test": "vitest run"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "express": "^4.21.2",
    "undici": "^7.2.0",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^4.1.9"
  }
}

# /etc/smartstudio-mcp/env  (mode 0640, owner root:smartstudio)
#
# All values are required.

# Where the colocated SmartStudio backend listens.
SMARTSTUDIO_URL=http://127.0.0.1:3001

# Interface and port to bind. Keep on loopback; let nginx do TLS + public exposure.
MCP_HOST=127.0.0.1
MCP_PORT=3101

# Long random secret. Generate with: openssl rand -hex 32
# Provide via AWX vault credentials; never commit a real value.
MCP_AUTH_TOKEN=replace-with-32-byte-random-hex

NODE_ENV=production

{
  "name": "smartstudio",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n vite,server -c blue,magenta \"vite\" \"cargo watch --workdir server -w src -w Cargo.toml -x run\"",
    "dev:client": "vite",
    "dev:server": "cargo run --manifest-path server/Cargo.toml",
    "dev:server:watch": "cargo watch --workdir server -w src -w Cargo.toml -x run",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/react-router": "^1.167.5",
    "@tanstack/react-table": "^8.21.3",
    "better-sqlite3": "^12.8.0",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "eta": "^4.5.1",
    "express": "^5.2.1",
    "lucide-react": "^0.577.0",
    "pg": "^8.20.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "simple-git": "^3.33.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "uuid": "^13.0.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^24.12.0",
    "@types/pg": "^8.18.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1",
    "vitest": "^3.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/user-event": "^14.0.0",
    "jsdom": "^26.0.0",
    "@types/jsdom": "^21.0.0"
  }
}
